{
  "name": "scry",
  "version": "0.1.0",
  "type": "module",
  "license": "Apache-2.0",
  "author": {
    "name": "Van Bai",
    "email": "baifanf@hotmail.com"
  },
  "bin": {
    "scry": "dist/bin.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "resources/"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"tsc --watch\" \"vite build --watch\"",
    "dev:devices": "tsx src/bin.ts devices",
    "dev:doctor": "tsx src/bin.ts doctor",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc && vite build",
    "start": "node dist/bin.js start",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/vite": "^9.0.2",
    "@fastify/websocket": "^11.2.0",
    "@squircle-js/react": "^1.3.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "fastify": "^5.8.5",
    "json5": "^2.2.3",
    "lucide-react": "^1.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "unicode-animations": "^1.0.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@sindresorhus/tsconfig": "^8.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.5.1",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rollup": "^4.60.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.3.3"
  }
}
